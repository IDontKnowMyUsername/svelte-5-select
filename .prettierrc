{
    "useTabs": false,
    "singleQuote": true,
    "tabWidth": 4,
    "printWidth": 120,
    "bracketSameLine": true,
    "plugins": ["prettier-plugin-svelte"],
    "overrides": [
        {
            "files": ["*.svelte"],
            "options": {
                "parser": "svelte"
            }
        }
    ]
}
