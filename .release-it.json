{
    "git": {
        "commitMessage": "chore: release v${version}",
        "tagName": "v${version}"
    },
    "npm": {
        "publish": false
    },
    "github": {
        "release": true
    },
    "hooks": {
        "before:init": ["pnpm run check", "pnpm run test:run"],
        "after:bump": ["node scripts/check-changelog.mjs ${version}", "pnpm run package"],
        "before:git:release": "pnpm run lint:package && pnpm run smoke"
    },
    "plugins": {
        "@release-it/conventional-changelog": {
            "preset": {
                "name": "conventionalcommits"
            }
        }
    }
}
